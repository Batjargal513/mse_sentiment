# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and service/anon key from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# ── Telegram (get from https://my.telegram.org) ───────────────────────────────
# Log in with your phone number, create an application, copy the values below.
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=your-telegram-api-hash
TELEGRAM_PHONE=+976XXXXXXXX

# ── Groq (company AI summaries) — https://console.groq.com/keys ────────────────
GROQ_API_KEY=your-groq-key

# ── Twitter/X (optional social source via Scweet) ─────────────────────────────
# auth_token cookie from a THROWAWAY x.com account (DevTools → Application →
# Cookies → https://x.com → copy `auth_token`). Leave blank to skip Twitter.
X_AUTH_TOKEN=your-x-auth-token

# ── Anthropic (Claude Haiku 4.5 sentiment scoring) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-key

# ── OpenAI (legacy — no longer used for scoring; keep if you want to switch back)
OPENAI_API_KEY=your-openai-key
